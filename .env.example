# Analytics (Matomo) — leave empty in the public repo.
# Set these to YOUR OWN Matomo instance to enable analytics; empty = no tracking.
# Never point a fork at someone else's endpoint. IP anonymization must be enabled
# in your Matomo admin — the app does not enforce it.
PUBLIC_MATOMO_URL=""
PUBLIC_MATOMO_SITE_ID=""

# Amazon Associates (affiliate) — leave empty in the public repo.
# Set these in your deployment env to enable affiliate links; unset = no link.
PUBLIC_AMAZON_STORE_ID=""
PUBLIC_AFFILIATE_PTE560BT=""
PUBLIC_AFFILIATE_PTP710BT=""
PUBLIC_AFFILIATE_TZE231=""
PUBLIC_AFFILIATE_MAGNETS=""

# Privacy policy — operator-specific details shown in the in-app policy.
# Leave empty on a fork and the policy renders a neutral self-hosted notice.
PUBLIC_CONTACT_EMAIL=""
PUBLIC_PRIVACY_CONTROLLER=""

# API origins allowed to call /api/shorten (the QR URL shortener).
# Comma-separated origins for YOUR deployment, e.g.
# "https://example.com,https://www.example.com". localhost dev origins are always
# allowed. Empty = only localhost (the shortener 403s from other domains).
PUBLIC_ALLOWED_ORIGINS=""
