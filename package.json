{
	"name": "gridscribe",
	"private": true,
	"version": "2.5.4",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "pnpm build-standards",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "(svelte-kit sync || echo '') && (command -v husky >/dev/null 2>&1 && husky || echo 'Husky not found, skipping')",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint-staged": "lint-staged",
		"test:unit": "vitest",
		"test:unit:coverage": "vitest run --coverage",
		"test": "pnpm test:unit --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"scrape-images": "node scripts/download-images.js",
		"analyze-images": "node scripts/analyze-aspect-ratios.mjs",
		"build-standards": "node scripts/build-all-standards.js",
		"validate-images": "node scripts/validate-images.js",
		"generate-dinmedia-mappings": "node scripts/generate-dinmedia-mappings.js",
		"scrape-dinmedia": "node scripts/scrape-dinmedia-metadata.js",
		"scrape-dinmedia:force": "node scripts/scrape-dinmedia-metadata.js --force",
		"check-changelog": "node scripts/check-changelog.js",
		"release": "node scripts/release.js",
		"release:dry-run": "node scripts/release.js --dry-run",
		"commitlint": "commitlint"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.3.0",
		"@commitlint/config-conventional": "^20.3.0",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@fontsource/fira-mono": "^5.0.0",
		"@internationalized/date": "^3.8.2",
		"@lucide/svelte": "^0.515.0",
		"@neoconfetti/svelte": "^2.0.0",
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-node": "^5.3.3",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@types/qrcode": "^1.5.5",
		"@vitest/browser": "^3.2.3",
		"@vitest/coverage-v8": "^3.2.4",
		"bits-ui": "^2.8.12",
		"clsx": "^2.1.1",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"image-size": "^2.0.2",
		"jsdom": "^27.0.0",
		"lint-staged": "^16.2.4",
		"playwright": "^1.53.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"sharp": "^0.34.4",
		"svelte": "^5.25.0",
		"svelte-check": "^4.0.0",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.6",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^7.0.4",
		"vitest": "^3.2.3",
		"vitest-browser-svelte": "^0.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@fontsource/noto-sans": "^5.2.7",
		"@fontsource/oswald": "^5.2.6",
		"@lume/kiwi": "^0.4.4",
		"ipaddr.js": "^2.2.0",
		"qrcode": "^1.5.4",
		"svelte-qrcode": "^1.0.1",
		"zustand": "^5.0.6"
	},
	"lint-staged": {
		"*.{ts,js,mjs,svelte}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css,html}": [
			"prettier --write"
		]
	}
}
