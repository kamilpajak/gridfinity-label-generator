{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"properties": {
		"family": { "type": "string" },
		"shape": { "type": "object" },
		"alias_of": { "type": "string" },
		"hardwareType": {
			"enum": ["washer", "nut", "screw", "pin", "self_tapping", "ring"]
		},
		"source": { "type": "string", "minLength": 3 },
		"verified": { "type": "boolean" },
		"designations": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["system", "code"],
				"properties": {
					"system": { "type": "string" },
					"code": { "type": "string" }
				}
			}
		}
	},
	"required": ["hardwareType", "source", "designations"],
	"oneOf": [
		{ "required": ["family", "shape"], "not": { "required": ["alias_of"] } },
		{ "required": ["alias_of"], "not": { "required": ["family", "shape"] } }
	]
}
