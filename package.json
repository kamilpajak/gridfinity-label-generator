{
	"name": "gridscribe",
	"private": true,
	"version": "3.0.0",
	"license": "AGPL-3.0-only",
	"type": "module",
	"packageManager": "pnpm@11.1.3",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "(svelte-kit sync || echo '') && (command -v husky >/dev/null 2>&1 && husky || echo 'Husky not found, skipping')",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint-staged": "lint-staged",
		"test:unit": "vitest",
		"test:unit:coverage": "vitest run --coverage",
		"test": "pnpm test:unit --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"analyze-images": "node scripts/analyze-aspect-ratios.mjs",
		"validate-images": "node scripts/validate-images.js",
		"standards:validate": "node scripts/standards-validate.js",
		"standards:resolve": "node scripts/standards-resolve.js",
		"standards:fetch": "node scripts/standards-fetch.js",
		"standards:fetch:force": "node scripts/standards-fetch.js --force",
		"standards:build": "node scripts/standards-build.js",
		"standards:build:strict": "node scripts/standards-build.js --strict",
		"standards:refresh": "pnpm standards:fetch && pnpm standards:build",
		"standards:add": "pnpm standards:validate && pnpm standards:resolve && pnpm standards:fetch && pnpm standards:build",
		"build-standards": "pnpm standards:validate && pnpm standards:build",
		"release": "node scripts/release.js",
		"release:dry-run": "node scripts/release.js --dry-run",
		"commitlint": "commitlint"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.3.0",
		"@commitlint/config-conventional": "^20.3.0",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@fontsource/fira-mono": "^5.2.7",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^0.515.0",
		"@neoconfetti/svelte": "^2.0.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/js-levenshtein": "^1.1.3",
		"@types/qrcode": "^1.5.6",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"image-size": "^2.0.2",
		"jsdom": "^27.0.0",
		"lint-staged": "^16.2.4",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sharp": "^0.35.3",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.23.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.2.0"
	},
	"dependencies": {
		"@fontsource/noto-sans": "^5.2.10",
		"@fontsource/oswald": "^5.2.8",
		"@lume/kiwi": "^0.4.4",
		"ipaddr.js": "^2.4.0",
		"js-levenshtein": "^1.1.6",
		"qrcode": "^1.5.4",
		"svelte-dnd-action": "^0.9.70",
		"zustand": "^5.0.14"
	},
	"lint-staged": {
		"*.{ts,js,mjs,svelte}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css,html}": [
			"prettier --write"
		]
	}
}
