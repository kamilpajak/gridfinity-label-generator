{
  "name": "gridfinity-label-generator",
  "description": "Label generator for storage systems, with a focus on the Gridfinity system",
  "version": "0.1.28",
  "engines": {
    "node": ">=20.17.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/express/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write \"src/**/*.{ts,tsx,qwik}\"",
    "fmt.check": "prettier --check \"src/**/*.{ts,tsx,qwik}\"",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "serve": "node server/entry.express",
    "start": "vite --open --mode ssr",
    "qwik": "qwik",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:auto": "bash scripts/release.sh",
    "release:branch": "bash scripts/release.sh --branch",
    "release:branch:patch": "bash scripts/release.sh --branch --patch",
    "release:branch:minor": "bash scripts/release.sh --branch --minor",
    "release:branch:major": "bash scripts/release.sh --branch --major",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.14.1",
    "@builder.io/qwik-city": "^1.14.1",
    "@eslint/js": "^9.28.0",
    "@noma.to/qwik-testing-library": "^1.3.2",
    "@qwikest/icons": "^0.0.13",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/eslint": "9.6.1",
    "@types/express": "^5.0.3",
    "@types/node": "24.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/validator": "^13.15.1",
    "@typescript-eslint/eslint-plugin": "8.34.0",
    "@typescript-eslint/parser": "8.34.0",
    "@vitest/coverage-v8": "^3.2.3",
    "compression": "^1.7.4",
    "dotenv": "^16.5.0",
    "eslint": "9.28.0",
    "eslint-plugin-qwik": "^1.14.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.0",
    "postcss": "^8.5.5",
    "prettier": "3.5.3",
    "pretty-quick": "^4.2.2",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.10",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.3"
  },
  "dependencies": {
    "express": "^5.1.0",
    "qrcode": "^1.5.4",
    "validator": "^13.15.15"
  }
}
